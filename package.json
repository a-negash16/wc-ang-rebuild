{
  "name": "wc-ang-rebuild",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Parallel rebuild for WC ANG prediction league.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "node --test",
    "generate:session-secret": "node scripts/generate-session-secret.mjs",
    "generate:manager-pins": "node scripts/generate-manager-pins.mjs",
    "hash-pin": "node scripts/hash-pin.mjs",
    "set-manager-pin": "node scripts/set-manager-pin.mjs",
    "smoke:prediction": "node scripts/smoke-prediction-flow.mjs",
    "supabase:bundle": "node scripts/build-supabase-sql.mjs",
    "supabase:check": "node scripts/check-supabase.mjs",
    "deployment:check": "node scripts/check-deployment-env.mjs",
    "check": "node --check src/rules/scoring.js && node --check src/rules/predictions.js && node --check src/integrations/odds-api.js && node --check src/integrations/fifa-api.js && node --check src/lib/auth/pin.js && node --check src/lib/auth/session.js && node --check src/data/league.js && node --test"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
